# FocusFlow environment template — copy to .env and fill in real values

# ── PocketBase (new instance via SSH tunnel on OpenClaw server) ─────────────
# SSH host alias from ~/.ssh/config (run scripts/setup-ssh.bat on new machines)
PB_SSH_HOST=openclaw

# API token (preferred — password auth may be disabled):
# Create in PocketBase admin UI → Settings → API keys
PB_API_TOKEN=

# Fallback: password auth (only used if PB_API_TOKEN is empty)
PB_EMAIL=
PB_PASSWORD=

# ── PocketBase (legacy sync_manager / init_pb — old instance) ───────────────
PB_URL=http://<old-server-ip>:8090/api/
